<view class="container">
  <view class="card">
    <view class="section-title">筛选条件</view>
    <view class="form-label">片区</view>
    <picker class="picker" mode="selector" range="{{areaBands}}" value="{{pickerIndex.areaBand}}" bindchange="onAreaChange">
      <view>{{filters.areaBand}}</view>
    </picker>

    <view class="form-label" style="margin-top: 16rpx;">房型</view>
    <picker class="picker" mode="selector" range="{{roomTypes}}" value="{{pickerIndex.roomType}}" bindchange="onRoomChange">
      <view>{{filters.roomType}}</view>
    </picker>

    <view class="form-label" style="margin-top: 16rpx;">电梯</view>
    <picker class="picker" mode="selector" range="{{elevatorOptions}}" value="{{pickerIndex.elevator}}" bindchange="onElevatorChange">
      <view>{{filters.elevator}}</view>
    </picker>

    <view class="form-label" style="margin-top: 16rpx;">预算</view>
    <picker class="picker" mode="selector" range="{{budgetOptions}}" value="{{pickerIndex.budget}}" bindchange="onBudgetChange">
      <view>{{filters.budget}}</view>
    </picker>
  </view>

  <view class="card">
    <view class="row-between">
      <view class="section-title">可看房源</view>
      <view class="muted">{{listings.length}} 套</view>
    </view>
    <block wx:if="{{listings.length}}">
      <block wx:for="{{listings}}" wx:key="id">
        <view class="listing-card" data-id="{{item.id}}" bindtap="openDetail">
          <view class="row-between">
            <view class="listing-title">{{item.title}}</view>
            <view class="listing-price">{{item.rentLabel}}</view>
          </view>
          <view class="meta-text">{{item.village}} · {{item.roomType}} · {{item.depositRule}}</view>
          <view class="meta-text">{{item.sunlight}} · {{item.elevator === '有' ? '有电梯' : '无电梯'}}</view>
          <view class="meta-text">最近核验：{{item.verifiedLabel}}</view>
          <view class="wrap" style="margin-top: 12rpx;">
            <block wx:for="{{item.safetyTags}}" wx:key="*this">
              <view class="chip chip-muted">{{item}}</view>
            </block>
          </view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">当前筛选条件下暂无可展示房源</view>
  </view>
</view>
