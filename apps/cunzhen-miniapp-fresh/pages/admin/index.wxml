<view class="container">
  <block wx:if="{{!session}}">
    <view class="card hero-card">
      <view class="title">运营后台登录</view>
      <view class="subtitle">登录后可管理房源状态、线索状态和带看进度</view>
    </view>
    <view class="form-section">
      <view class="form-label">管理员密码</view>
      <input class="input" password="true" value="{{password}}" bindinput="onPasswordInput" placeholder="输入后台密码" />
      <button class="btn-primary" style="margin-top: 24rpx;" bindtap="login">登录后台</button>
    </view>
  </block>

  <block wx:elif="{{summary}}">
    <view class="card hero-card">
      <view class="row-between">
        <view>
          <view class="title">运营漏斗总览</view>
          <view class="subtitle">欢迎，{{session.username}}</view>
        </view>
        <button class="btn-ghost" bindtap="logout">退出</button>
      </view>
      <view class="grid-2" style="margin-top: 24rpx;">
        <view class="stat-card">
          <view class="stat-label">可发布房源</view>
          <view class="stat-value">{{summary.publishableCount}}</view>
        </view>
        <view class="stat-card">
          <view class="stat-label">失效风险</view>
          <view class="stat-value">{{summary.expiredCount}}</view>
        </view>
        <view class="stat-card">
          <view class="stat-label">待核验房源</view>
          <view class="stat-value">{{summary.pendingReviewCount}}</view>
        </view>
        <view class="stat-card">
          <view class="stat-label">新线索</view>
          <view class="stat-value">{{summary.leadStatusCount['新线索'] || 0}}</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="row-between">
        <view class="section-title">线索状态</view>
        <button class="btn-secondary" bindtap="goSupplyForm">提报新房源</button>
      </view>
      <view class="wrap">
        <block wx:for="{{leadStats}}" wx:key="label">
          <view class="chip chip-muted">{{item.label}} {{item.value}}</view>
        </block>
      </view>
    </view>

    <view class="card">
      <view class="section-title">带看状态</view>
      <view class="wrap">
        <block wx:for="{{viewingStats}}" wx:key="label">
          <view class="chip">{{item.label}} {{item.value}}</view>
        </block>
      </view>
    </view>

    <view class="card">
      <view class="section-title">风险房源</view>
      <block wx:if="{{summary.riskyListings.length}}">
        <block wx:for="{{summary.riskyListings}}" wx:key="id">
          <view class="listing-card">
            <view class="row-between">
              <view class="listing-title">{{item.title}}</view>
              <view class="chip chip-muted">{{item.status}}</view>
            </view>
            <view class="meta-text">{{item.village}} · {{item.roomType}}</view>
            <view class="meta-text">{{item.publishable ? '资料完整' : '资料不完整'}} · {{item.verificationLabel}}</view>
            <button class="btn-secondary" style="margin-top: 16rpx;" data-id="{{item.id}}" data-status="{{item.status}}" data-auth-flag="{{item.authFlag}}" bindtap="openListingActions">更新房源</button>
          </view>
        </block>
      </block>
      <view wx:else class="empty">当前没有风险房源</view>
    </view>

    <view class="card">
      <view class="section-title">最新房源</view>
      <block wx:for="{{summary.latestListings}}" wx:key="id">
        <view class="listing-card">
          <view class="row-between">
            <view class="listing-title">{{item.title}}</view>
            <view class="chip">{{item.authFlag}}</view>
          </view>
          <view class="meta-text">{{item.village}} · {{item.roomType}} · {{item.status}}</view>
          <button class="btn-secondary" style="margin-top: 16rpx;" data-id="{{item.id}}" data-status="{{item.status}}" data-auth-flag="{{item.authFlag}}" bindtap="openListingActions">管理状态</button>
        </view>
      </block>
    </view>

    <view class="card">
      <view class="section-title">最新线索</view>
      <block wx:for="{{summary.latestLeads}}" wx:key="id">
        <view class="listing-card">
          <view class="row-between">
            <view class="listing-title">{{item.name}}</view>
            <view class="chip">{{item.priority}}</view>
          </view>
          <view class="meta-text">{{item.workArea}} · {{item.roomPreference}} · {{item.budgetMin}}-{{item.budgetMax}}</view>
          <view class="meta-text">{{item.status}} · {{item.contact}}</view>
          <button class="btn-secondary" style="margin-top: 16rpx;" data-id="{{item.id}}" data-status="{{item.status}}" bindtap="openLeadActions">更新线索状态</button>
        </view>
      </block>
    </view>

    <view class="card">
      <view class="section-title">最新带看</view>
      <block wx:for="{{summary.latestViewings}}" wx:key="id">
        <view class="listing-card">
          <view class="row-between">
            <view class="listing-title">{{item.leadName}}</view>
            <view class="chip chip-muted">{{item.status}}</view>
          </view>
          <view class="meta-text">{{item.listingTitle}}</view>
          <view class="meta-text">{{item.preferredDate}} · {{item.timeSlot}}</view>
          <button class="btn-secondary" style="margin-top: 16rpx;" data-id="{{item.id}}" data-status="{{item.status}}" bindtap="openViewingActions">更新带看状态</button>
        </view>
      </block>
    </view>
  </block>
</view>
